# ─── Backend Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env — only .env.example goes to Git.

PORT=5010
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/swarojgar

# JWT
JWT_SECRET=change_this_to_a_long_random_string_in_production

# Blockchain (Sepolia)
BLOCKCHAIN_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
BLOCKCHAIN_PRIVATE_KEY=0xYourDeployerPrivateKey
ESCROW_CONTRACT_ADDRESS=0xYourEscrowContractAddress
TOKEN_CONTRACT_ADDRESS=0xYourSRTTokenAddress

# Grok / xAI (Tier 1 AI dispute resolution — get key at console.x.ai)
GROK_API_KEY=xai-...

# Pinata IPFS (evidence & MetaEvidence uploads)
PINATA_JWT=eyJ...

# Admin secret (for protected human arbitration endpoint)
ADMIN_SECRET=change_this_in_production
