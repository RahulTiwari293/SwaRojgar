# ─── Frontend Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env — only .env.example goes to Git.

# Deployed backend URL (use http://localhost:5010 for local dev)
VITE_BACKEND_URL=https://your-backend.onrender.com

# Deployed smart contract addresses (Sepolia testnet)
VITE_ESCROW_CONTRACT_ADDRESS=0xYourEscrowContractAddress
VITE_TOKEN_CONTRACT_ADDRESS=0xYourSRTTokenAddress
